fun main(){
    var valores = mutableListOf<Double>()
    var soma = 0.0
    for (i in 1..4){
        println("Informe o $i° valor: ")
        var valor = readLine()!!.toDouble()
        valores.add(valor)
        if (valor > 0 && valor < 10){
            soma += valor
        }
    }
    var media = soma / 4.0

    if (media > 5){
        println("Você passou no teste!")
    } else {
        println("tente novamente")
    }
}
