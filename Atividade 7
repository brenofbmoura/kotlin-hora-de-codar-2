fun main(){
    var valores = mutableListOf<Int>()
   var soma = 0
    for (i in 1..6){
        println("Digite o $i° valor: ")
        var valor = readln().toInt()
        valores.add(valor)
        if (valor < 72){
            soma += valor
        }
    }
    println("Soma: $soma")
    println("Números listados: $valores")
}
